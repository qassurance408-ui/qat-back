# Server
PORT=3000
NODE_ENV=development

# Database (AletCloud Database hosting) — individual components
# The app constructs the full connection URL from these.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=qa_tracker
DB_SSL=false

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AletCloud Object Storage (S3-compatible)
S3_ENDPOINT=https://storage.aletcloud.com
S3_REGION=et-addis-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=qa-tracker-attachments

# CORS
CORS_ORIGIN=http://localhost:4200
